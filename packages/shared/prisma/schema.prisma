generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────

enum AcademicYearStatus {
  ACTIVE
  ARCHIVED
}

enum SlotType {
  PERIOD
  INTERVAL
  LUNCH_BREAK
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum ConflictType {
  TEACHER_CHANGED
  TEACHER_DELETED
  SUBJECT_CHANGED
  SUBJECT_DELETED
  ASSIGNMENT_CHANGED
  SLOT_CHANGED
  STRUCTURE_CHANGED
  AVAILABILITY_CHANGED
  ELECTIVE_GROUP_CHANGED
  SWAP_CONFLICT
}

enum UserRole {
  SUPER_ADMIN
  SCHOOL_ADMIN
  VIEWER
}

// ──────────────────────────────────────────────
// Table 1: schools
// ──────────────────────────────────────────────

model School {
  id            String   @id @default(uuid())
  name          String   @db.VarChar(255)
  adminEmail    String   @unique @map("admin_email") @db.VarChar(255)
  cognitoUserId String   @unique @map("cognito_user_id") @db.VarChar(255)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  academicYears          AcademicYear[]
  classes                Class[]
  divisions              Division[]
  subjects               Subject[]
  teachers               Teacher[]
  teacherSubjects        TeacherSubject[]
  teacherAvailability    TeacherAvailability[]
  periodStructures       PeriodStructure[]
  workingDays            WorkingDay[]
  slots                  Slot[]
  electiveGroups         ElectiveGroup[]
  electiveGroupSubjects  ElectiveGroupSubject[]
  divisionAssignments    DivisionAssignment[]
  timetables             Timetable[]
  timetableSlots         TimetableSlot[]
  generationJobs         GenerationJob[]
  timetableNotifications TimetableNotification[]
  setupWizardStates      SetupWizardState[]
  schoolUsers            SchoolUser[]

  @@map("schools")
}

// ──────────────────────────────────────────────
// Table 1b: school_users (multi-user access)
// ──────────────────────────────────────────────

model SchoolUser {
  id        String   @id @default(uuid())
  email     String   @db.VarChar(255)
  schoolId  String?  @map("school_id")
  role      UserRole
  createdAt DateTime @default(now()) @map("created_at")

  school School? @relation(fields: [schoolId], references: [id])

  @@unique([email, schoolId])
  @@index([email])
  @@map("school_users")
}

// ──────────────────────────────────────────────
// Table 2: academic_years
// ──────────────────────────────────────────────

model AcademicYear {
  id        String             @id @default(uuid())
  schoolId  String             @map("school_id")
  label     String             @db.VarChar(50)
  startDate DateTime           @map("start_date") @db.Date
  endDate   DateTime           @map("end_date") @db.Date
  status    AcademicYearStatus @default(ARCHIVED)
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")
  deletedAt DateTime?          @map("deleted_at")

  school              School               @relation(fields: [schoolId], references: [id])
  classes             Class[]
  divisions           Division[]
  subjects            Subject[]
  teachers            Teacher[]
  teacherAvailability TeacherAvailability[]
  periodStructures    PeriodStructure[]
  electiveGroups      ElectiveGroup[]
  divisionAssignments DivisionAssignment[]
  timetables          Timetable[]
  generationJobs      GenerationJob[]
  setupWizardStates   SetupWizardState[]

  @@index([schoolId, status])
  @@map("academic_years")
}

// ──────────────────────────────────────────────
// Table 3: classes
// ──────────────────────────────────────────────

model Class {
  id              String    @id @default(uuid())
  schoolId        String    @map("school_id")
  academicYearId  String    @map("academic_year_id")
  name            String    @db.VarChar(100)
  sortOrder       Int       @default(0) @map("sort_order")
  requiresStream  Boolean   @default(false) @map("requires_stream")
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  school              School                 @relation(fields: [schoolId], references: [id])
  academicYear        AcademicYear           @relation(fields: [academicYearId], references: [id])
  divisions           Division[]

  @@unique([schoolId, academicYearId, name])
  @@index([schoolId, academicYearId, sortOrder])
  @@map("classes")
}

// ──────────────────────────────────────────────
// Table 4: divisions
// ──────────────────────────────────────────────

model Division {
  id                String    @id @default(uuid())
  schoolId          String    @map("school_id")
  classId           String    @map("class_id")
  academicYearId    String    @map("academic_year_id")
  label             String    @db.VarChar(10)
  streamName        String?   @map("stream_name") @db.VarChar(100)
  periodStructureId String?   @map("period_structure_id")
  classTeacherId    String?   @map("class_teacher_id")
  deletedAt         DateTime? @map("deleted_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  school              School               @relation(fields: [schoolId], references: [id])
  class               Class                @relation(fields: [classId], references: [id])
  academicYear        AcademicYear         @relation(fields: [academicYearId], references: [id])
  periodStructure     PeriodStructure?     @relation(fields: [periodStructureId], references: [id])
  classTeacher        Teacher?             @relation("ClassTeacher", fields: [classTeacherId], references: [id])
  divisionAssignments DivisionAssignment[]
  timetables          Timetable[]
  generationJobs      GenerationJob[]
  timetableNotifications TimetableNotification[]

  @@unique([schoolId, classId, label, streamName])
  @@index([schoolId, classId, academicYearId])
  @@index([periodStructureId])
  @@index([classTeacherId])
  @@map("divisions")
}

// ──────────────────────────────────────────────
// Table 5: subjects
// ──────────────────────────────────────────────

model Subject {
  id             String    @id @default(uuid())
  schoolId       String    @map("school_id")
  academicYearId String    @map("academic_year_id")
  name           String    @db.VarChar(255)
  abbreviation   String?   @db.VarChar(10)
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  school              School                 @relation(fields: [schoolId], references: [id])
  academicYear        AcademicYear           @relation(fields: [academicYearId], references: [id])
  teacherSubjects     TeacherSubject[]
  electiveGroupSubjects ElectiveGroupSubject[]
  divisionAssignments DivisionAssignment[]

  @@unique([schoolId, academicYearId, name])
  @@map("subjects")
}

// ──────────────────────────────────────────────
// Table 6: teachers
// ──────────────────────────────────────────────

model Teacher {
  id                String    @id @default(uuid())
  schoolId          String    @map("school_id")
  academicYearId    String    @map("academic_year_id")
  name              String    @db.VarChar(255)
  contact           String?   @db.Text
  maxPeriodsPerWeek Int?      @map("max_periods_per_week")
  deletedAt         DateTime? @map("deleted_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  school                School               @relation(fields: [schoolId], references: [id])
  academicYear          AcademicYear         @relation(fields: [academicYearId], references: [id])
  teacherSubjects       TeacherSubject[]
  teacherAvailability   TeacherAvailability[]
  divisionAssignments   DivisionAssignment[] @relation("PrimaryTeacher")
  assistantAssignments  DivisionAssignment[] @relation("AssistantTeacher")
  classTeacherDivisions Division[]           @relation("ClassTeacher")

  @@index([schoolId, academicYearId])
  @@map("teachers")
}

// ──────────────────────────────────────────────
// Table 7: teacher_subjects
// ──────────────────────────────────────────────

model TeacherSubject {
  id        String @id @default(uuid())
  schoolId  String @map("school_id")
  teacherId String @map("teacher_id")
  subjectId String @map("subject_id")

  school  School  @relation(fields: [schoolId], references: [id])
  teacher Teacher @relation(fields: [teacherId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])

  @@unique([teacherId, subjectId])
  @@map("teacher_subjects")
}

// ──────────────────────────────────────────────
// Table 8: teacher_availability
// ──────────────────────────────────────────────

model TeacherAvailability {
  id             String @id @default(uuid())
  schoolId       String @map("school_id")
  teacherId      String @map("teacher_id")
  academicYearId String @map("academic_year_id")
  workingDayId   String @map("working_day_id")
  slotId         String @map("slot_id")

  school       School       @relation(fields: [schoolId], references: [id])
  teacher      Teacher      @relation(fields: [teacherId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])
  workingDay   WorkingDay   @relation(fields: [workingDayId], references: [id])
  slot         Slot         @relation(fields: [slotId], references: [id])

  @@unique([teacherId, academicYearId, workingDayId, slotId])
  @@map("teacher_availability")
}

// ──────────────────────────────────────────────
// Table 9: period_structures
// ──────────────────────────────────────────────

model PeriodStructure {
  id             String    @id @default(uuid())
  schoolId       String    @map("school_id")
  academicYearId String    @map("academic_year_id")
  name           String    @db.VarChar(255)
  periods        Json      @default("[]")
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  school       School                 @relation(fields: [schoolId], references: [id])
  academicYear AcademicYear           @relation(fields: [academicYearId], references: [id])
  divisions    Division[]
  workingDays  WorkingDay[]

  @@unique([schoolId, academicYearId, name])
  @@map("period_structures")
}

// ──────────────────────────────────────────────
// Table 10: working_days (renumbered — period_structure_classes removed)
// ──────────────────────────────────────────────

model WorkingDay {
  id                String @id @default(uuid())
  schoolId          String @map("school_id")
  periodStructureId String @map("period_structure_id")
  dayOfWeek         Int    @map("day_of_week")
  label             String @db.VarChar(20)
  sortOrder         Int    @map("sort_order")

  school              School              @relation(fields: [schoolId], references: [id])
  periodStructure     PeriodStructure     @relation(fields: [periodStructureId], references: [id])
  slots               Slot[]
  teacherAvailability TeacherAvailability[]
  timetableSlots      TimetableSlot[]

  @@unique([periodStructureId, dayOfWeek])
  @@map("working_days")
}

// ──────────────────────────────────────────────
// Table 12: slots
// ──────────────────────────────────────────────

model Slot {
  id           String   @id @default(uuid())
  schoolId     String   @map("school_id")
  workingDayId String   @map("working_day_id")
  slotType     SlotType @map("slot_type")
  slotNumber   Int?     @map("slot_number")
  startTime    DateTime @map("start_time") @db.Time()
  endTime      DateTime @map("end_time") @db.Time()
  sortOrder    Int      @map("sort_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  school              School              @relation(fields: [schoolId], references: [id])
  workingDay          WorkingDay          @relation(fields: [workingDayId], references: [id])
  teacherAvailability TeacherAvailability[]
  timetableSlots      TimetableSlot[]

  @@unique([workingDayId, sortOrder])
  @@map("slots")
}

// ──────────────────────────────────────────────
// Table 13: elective_groups
// ──────────────────────────────────────────────

model ElectiveGroup {
  id             String    @id @default(uuid())
  schoolId       String    @map("school_id")
  academicYearId String    @map("academic_year_id")
  name           String    @db.VarChar(255)
  periodsPerWeek Int       @default(0) @map("periods_per_week")
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  school              School                 @relation(fields: [schoolId], references: [id])
  academicYear        AcademicYear           @relation(fields: [academicYearId], references: [id])
  subjects            ElectiveGroupSubject[]
  divisionAssignments DivisionAssignment[]

  @@unique([schoolId, academicYearId, name])
  @@map("elective_groups")
}

// ──────────────────────────────────────────────
// Table 14: elective_group_subjects
// ──────────────────────────────────────────────

model ElectiveGroupSubject {
  id               String @id @default(uuid())
  schoolId         String @map("school_id")
  electiveGroupId  String @map("elective_group_id")
  subjectId        String @map("subject_id")
  parallelSections Int    @default(1) @map("parallel_sections")

  school        School        @relation(fields: [schoolId], references: [id])
  electiveGroup ElectiveGroup @relation(fields: [electiveGroupId], references: [id])
  subject       Subject       @relation(fields: [subjectId], references: [id])

  @@unique([electiveGroupId, subjectId])
  @@map("elective_group_subjects")
}

// ──────────────────────────────────────────────
// Table 15: division_assignments
// ──────────────────────────────────────────────

model DivisionAssignment {
  id                      String    @id @default(uuid())
  schoolId                String    @map("school_id")
  divisionId              String    @map("division_id")
  subjectId               String    @map("subject_id")
  teacherId               String?   @map("teacher_id")
  assistantTeacherId      String?   @map("assistant_teacher_id")
  weightage               Int
  electiveGroupId         String?   @map("elective_group_id")
  academicYearId          String    @map("academic_year_id")
  schedulingPreferences   Json?     @map("scheduling_preferences") @db.JsonB
  deletedAt               DateTime? @map("deleted_at")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  school           School         @relation(fields: [schoolId], references: [id])
  division         Division       @relation(fields: [divisionId], references: [id])
  subject          Subject        @relation(fields: [subjectId], references: [id])
  teacher          Teacher?       @relation("PrimaryTeacher", fields: [teacherId], references: [id])
  assistantTeacher Teacher?       @relation("AssistantTeacher", fields: [assistantTeacherId], references: [id])
  electiveGroup    ElectiveGroup? @relation(fields: [electiveGroupId], references: [id])
  academicYear     AcademicYear   @relation(fields: [academicYearId], references: [id])
  timetableSlots   TimetableSlot[]

  @@index([schoolId, divisionId, academicYearId])
  @@index([teacherId])
  @@index([assistantTeacherId])
  @@index([electiveGroupId])
  @@map("division_assignments")
}

// ──────────────────────────────────────────────
// Table 16: timetables
// ──────────────────────────────────────────────

model Timetable {
  id                          String          @id @default(uuid())
  schoolId                    String          @map("school_id")
  divisionId                  String          @map("division_id")
  academicYearId              String          @map("academic_year_id")
  statusJson                  Json?           @map("status_json")
  statusComputedAt            DateTime?       @map("status_computed_at")
  adjacencyConstraintEnabled  Boolean         @default(false) @map("adjacency_constraint_enabled")
  generatedAt                 DateTime        @map("generated_at")
  createdAt                   DateTime        @default(now()) @map("created_at")
  updatedAt                   DateTime        @updatedAt @map("updated_at")

  school                 School                @relation(fields: [schoolId], references: [id])
  division               Division              @relation(fields: [divisionId], references: [id])
  academicYear           AcademicYear          @relation(fields: [academicYearId], references: [id])
  timetableSlots         TimetableSlot[]
  timetableNotifications TimetableNotification[]

  @@unique([schoolId, divisionId, academicYearId])
  @@map("timetables")
}

// ──────────────────────────────────────────────
// Table 17: timetable_slots
// ──────────────────────────────────────────────

model TimetableSlot {
  id                   String  @id @default(uuid())
  schoolId             String  @map("school_id")
  timetableId          String  @map("timetable_id")
  workingDayId         String  @map("working_day_id")
  slotId               String  @map("slot_id")
  divisionAssignmentId String? @map("division_assignment_id")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  school             School              @relation(fields: [schoolId], references: [id])
  timetable          Timetable           @relation(fields: [timetableId], references: [id])
  workingDay         WorkingDay          @relation(fields: [workingDayId], references: [id])
  slot               Slot                @relation(fields: [slotId], references: [id])
  divisionAssignment DivisionAssignment? @relation(fields: [divisionAssignmentId], references: [id])

  // NOTE: a unique constraint on (timetableId, workingDayId, slotId) was
  // dropped in migration 20260411120000_allow_multi_assignment_slot to support
  // elective groups with parallel sections — multiple division_assignments
  // (one per parallel teacher) now share the same (day, slot) cell.
  @@index([timetableId, workingDayId, slotId])
  @@index([divisionAssignmentId])
  @@map("timetable_slots")
}

// ──────────────────────────────────────────────
// Table 18: generation_jobs
// ──────────────────────────────────────────────

model GenerationJob {
  id             String    @id @default(uuid())
  schoolId       String    @map("school_id")
  divisionId     String    @map("division_id")
  academicYearId String    @map("academic_year_id")
  status         JobStatus
  errorMessage   String?   @map("error_message")
  resultSummary  Json?     @map("result_summary")
  startedAt      DateTime? @map("started_at")
  completedAt    DateTime? @map("completed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  school       School       @relation(fields: [schoolId], references: [id])
  division     Division     @relation(fields: [divisionId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  @@index([schoolId, divisionId, academicYearId])
  @@map("generation_jobs")
}

// ──────────────────────────────────────────────
// Table 19: timetable_notifications
// ──────────────────────────────────────────────

model TimetableNotification {
  id                String       @id @default(uuid())
  schoolId          String       @map("school_id")
  timetableId       String       @map("timetable_id")
  divisionId        String       @map("division_id")
  conflictType      ConflictType @map("conflict_type")
  changeDescription String       @map("change_description")
  dismissed         Boolean      @default(false)
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  school    School    @relation(fields: [schoolId], references: [id])
  timetable Timetable @relation(fields: [timetableId], references: [id])
  division  Division  @relation(fields: [divisionId], references: [id])

  @@index([schoolId, dismissed])
  @@map("timetable_notifications")
}

// ──────────────────────────────────────────────
// Table 20: setup_wizard_state
// ──────────────────────────────────────────────

model SetupWizardState {
  id             String    @id @default(uuid())
  schoolId       String    @map("school_id")
  academicYearId String    @map("academic_year_id")
  dismissed      Boolean   @default(false)
  dismissedAt    DateTime? @map("dismissed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  school       School       @relation(fields: [schoolId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  @@unique([schoolId, academicYearId])
  @@map("setup_wizard_state")
}
