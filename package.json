{
  "name": "school-timetable-management",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "build:shared": "npm run build -w packages/shared",
    "prisma:generate": "npm run prisma:generate -w packages/shared",
    "prisma:migrate": "npm run prisma:migrate -w packages/shared",
    "prisma:studio": "npm run prisma:studio -w packages/shared",
    "db:seed": "npm run db:seed -w packages/shared",
    "dev:auth": "npm run dev -w services/auth",
    "dev:academic-year": "npm run dev -w services/academic-year",
    "dev:school-config": "npm run dev -w services/school-config",
    "dev:subject": "npm run dev -w services/subject",
    "dev": "concurrently --names auth,acad-yr,config,subject --prefix-colors blue,green,yellow,magenta \"npm run dev:auth\" \"npm run dev:academic-year\" \"npm run dev:school-config\" \"npm run dev:subject\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
